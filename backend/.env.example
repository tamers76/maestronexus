# maestronexus backend — environment configuration
# Copy to .env and adjust for your machine.

APP_NAME="The-Code Adaptive LMS"
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

# CORS (comma-separated origins) — Next.js dev server
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://maestro:maestro-dev-secret123@localhost:5432/maestronexus

# Redis (cache + job broker)
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO locally, S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=maestro
S3_SECRET_KEY=maestro-dev-secret123
S3_BUCKET=maestronexus
S3_REGION=us-east-1

# AI / LLM providers (see app/modules/ai/providers.py)
# All LLM access goes through the provider-abstraction layer (docs/18 D12).
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Additional vendors (fill to enable):
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=
# GOOGLE_API_KEY=
